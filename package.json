{
  "name": "generator-ccc",
  "version": "2.0.0-alpha.0",
  "description": "One-command setup and upgrade for Callaway Cloud Salesforce projects",
  "type": "module",
  "main": "dist/bin.js",
  "bin": {
    "generator-ccc": "dist/bin.js",
    "ccc": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "watch": "tsc -w",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "build:test": "tsc -p tsconfig.test-emit.json",
    "test": "npm run build:test && mocha test-dist/**/*.test.js --timeout 10000"
  },
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "salesforce",
    "sfdx",
    "scaffold",
    "cli",
    "bitbucket-pipelines"
  ],
  "files": [
    "dist",
    "templates"
  ],
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "deepmerge": "^4.3.1",
    "strip-json-comments": "^3.1.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.11",
    "@types/xml2js": "^0.4.14",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.6",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.4"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
